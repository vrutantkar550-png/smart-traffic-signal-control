<!--
simulation/networks/network_3way.net.xml

SUMO road network for a 3-way T-junction.

Structure:
        N
        |
W ──── junction
        |
        S

Nodes:   north, south, west, centre
Edges:   N, S, W in/out to centre
-->
<net version="1.16" junctionCornerDetail="5" limitTurnSpeed="5.83">

  <!-- ── Nodes ── -->
  <node id="north"  x="0.00"    y="200.00"  type="priority"/>
  <node id="south"  x="0.00"    y="-200.00" type="priority"/>
  <node id="west"   x="-200.00" y="0.00"    type="priority"/>
  <node id="centre" x="0.00"    y="0.00"    type="traffic_light"/>

  <!-- ── Edges ── -->
  <edge id="N_in"  from="north"  to="centre" numLanes="2" speed="13.89" priority="1"/>
  <edge id="S_in"  from="south"  to="centre" numLanes="2" speed="13.89" priority="1"/>
  <edge id="W_in"  from="west"   to="centre" numLanes="2" speed="13.89" priority="1"/>

  <edge id="N_out" from="centre" to="north"  numLanes="2" speed="13.89" priority="1"/>
  <edge id="S_out" from="centre" to="south"  numLanes="2" speed="13.89" priority="1"/>
  <edge id="W_out" from="centre" to="west"   numLanes="2" speed="13.89" priority="1"/>

  <!-- ── Traffic light — 3 phases ── -->
  <tlLogic id="centre" type="static" programID="0" offset="0">
    <!-- Phase 0: North green only — 25s -->
    <phase duration="25" state="GGrrrr"/>
    <phase duration="3"  state="yyrrrr"/>
    <!-- Phase 1: South + West green — 25s -->
    <phase duration="25" state="rrGGGG"/>
    <phase duration="3"  state="rryyy y"/>
    <!-- Phase 2: West green only — 20s -->
    <phase duration="20" state="rrrrGG"/>
    <phase duration="3"  state="rrrryy"/>
  </tlLogic>

  <!-- ── Connections ── -->
  <connection from="N_in" to="N_out" fromLane="0" toLane="0"/>
  <connection from="N_in" to="S_out" fromLane="0" toLane="0"/>
  <connection from="N_in" to="W_out" fromLane="1" toLane="0"/>

  <connection from="S_in" to="S_out" fromLane="0" toLane="0"/>
  <connection from="S_in" to="N_out" fromLane="0" toLane="0"/>
  <connection from="S_in" to="W_out" fromLane="1" toLane="0"/>

  <connection from="W_in" to="W_out" fromLane="0" toLane="0"/>
  <connection from="W_in" to="N_out" fromLane="0" toLane="0"/>
  <connection from="W_in" to="S_out" fromLane="1" toLane="0"/>

</net>
