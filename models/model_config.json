{
  "_comment": "This file records training metadata for each model. Update it every time you retrain.",

  "traffic_rl_agent": {
    "file": "traffic_rl_agent.zip",
    "algorithm": "PPO",
    "library": "stable-baselines3",
    "version": null,
    "trained_on": {
      "junction_types": ["4way"],
      "total_timesteps": 1000000,
      "n_envs": 8,
      "episode_length_s": 3600,
      "emergency_probability": 0.002
    },
    "hyperparameters": {
      "n_steps": 2048,
      "batch_size": 256,
      "n_epochs": 10,
      "gamma": 0.99,
      "gae_lambda": 0.95,
      "clip_range": 0.2,
      "ent_coef": 0.01,
      "learning_rate": 0.0003,
      "policy_net_arch": [256, 256]
    },
    "observation_space": {
      "size": 8,
      "features": [
        "N_vehicle_count",
        "S_vehicle_count",
        "E_vehicle_count",
        "W_vehicle_count",
        "current_phase_index",
        "time_in_phase_s",
        "emergency_active",
        "emergency_direction_encoded"
      ]
    },
    "action_space": {
      "type": "Box",
      "shape": [2],
      "description": [
        "action[0]: phase selection (0-1 mapped to phase index)",
        "action[1]: duration fraction (0-1 mapped to 10-90 seconds)"
      ]
    },
    "reward_function": {
      "wait_penalty_per_vehicle": -1.0,
      "clear_queue_bonus": 10.0,
      "throughput_bonus_per_vehicle": 0.5,
      "phase_change_penalty": -2.0,
      "ambulance_block_penalty": -100.0,
      "fire_truck_block_penalty": -150.0,
      "accident_block_penalty": -30.0
    },
    "trained_date": null,
    "trained_by": null,
    "notes": "Set trained_date and trained_by after your first training run"
  },

  "yolo_detector": {
    "file": "yolo_detector.pt",
    "base_model": "yolov8n.pt",
    "framework": "ultralytics",
    "task": "object detection",
    "version": null,
    "trained_on": {
      "dataset": "traffic.yaml",
      "epochs": 100,
      "image_size": 640,
      "batch_size": 16,
      "classes": 8
    },
    "classes": {
      "0": "car",
      "1": "truck",
      "2": "bus",
      "3": "van",
      "4": "motorcycle",
      "5": "bicycle",
      "6": "auto-rickshaw",
      "7": "emergency_vehicle"
    },
    "hyperparameters": {
      "optimizer": "AdamW",
      "lr0": 0.001,
      "lrf": 0.01,
      "momentum": 0.937,
      "weight_decay": 0.0005,
      "warmup_epochs": 3.0,
      "augmentation": ["mosaic", "flip", "colour_jitter", "rotation_10deg"]
    },
    "expected_metrics": {
      "mAP50": ">0.75",
      "mAP50_95": ">0.55",
      "inference_time_ms": "<30"
    },
    "trained_date": null,
    "trained_by": null,
    "notes": "Use yolov8s.pt or yolov8m.pt as base for better accuracy at cost of speed"
  }
}

