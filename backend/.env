# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it is listed in .gitignore.

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=False

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/traffic_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS (React frontend URL) ─────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── ML Models ─────────────────────────────────────────────────────────────────
RL_MODEL_PATH=models/traffic_rl_agent.zip
YOLO_MODEL_PATH=models/yolo_detector.pt

# ── Signal Timing (seconds) ───────────────────────────────────────────────────
MIN_GREEN_TIME=10
MAX_GREEN_TIME=90
YELLOW_TIME=3
ALL_RED_TIME=2

# ── Emergency Hold Times (seconds) ───────────────────────────────────────────
EMERGENCY_HOLD_AMBULANCE=60
EMERGENCY_HOLD_FIRE=90
EMERGENCY_HOLD_ACCIDENT=120
EMERGENCY_HOLD_CONSTRUCTION=180
